dashboard.{$DOMAIN} {
  reverse_proxy web:3000
  encode gzip zstd
}

api.{$DOMAIN} {
  reverse_proxy api:3001
  encode gzip zstd
  header {
    X-Content-Type-Options nosniff
    X-Frame-Options SAMEORIGIN
    Strict-Transport-Security "max-age=31536000"
    -Server
  }
}

hotspot.{$DOMAIN} {
  root * /srv/hotspot
  file_server
}
