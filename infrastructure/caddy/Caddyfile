# Admin Dashboard — admin.skynity.org
admin.{$DOMAIN} {
  reverse_proxy web:3000
  encode gzip zstd
}

# User/Customer Portal — user.skynity.org
user.{$DOMAIN} {
  @root path /
  redir @root /portal 302

  reverse_proxy web:3000
  encode gzip zstd
}

# API Server — api.skynity.org
api.{$DOMAIN} {
  reverse_proxy api:3001
  encode gzip zstd
  header {
    X-Content-Type-Options nosniff
    X-Frame-Options SAMEORIGIN
    Strict-Transport-Security "max-age=31536000"
    -Server
  }
}

# Hotspot WiFi Portal — wifi.skynity.org
wifi.{$DOMAIN} {
  root * /srv/hotspot
  file_server
  encode gzip zstd
}
