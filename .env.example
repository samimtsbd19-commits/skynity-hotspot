# ── App
NODE_ENV=production
APP_URL=https://dashboard.skynity.net
PORT_API=3001
PORT_WEB=3000
MIKROTIK_MOCK=true

# ── PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=skynity
POSTGRES_USER=skynity_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis
REDIS_URL=redis://:CHANGE_ME@redis:6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── Auth
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING_HERE_USE_OPENSSL
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX_FOR_AES256

# ── Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CUSTOMER_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=123456789,987654321

# ── WireGuard (generated on first run by setup.sh)
WG_INTERFACE=wg0
WG_SERVER_PRIVATE_KEY=GENERATED_ON_SETUP
WG_SERVER_PUBLIC_KEY=GENERATED_ON_SETUP
WG_SERVER_IP=10.100.0.1/24
WG_LISTEN_PORT=51820
WG_DNS=1.1.1.1,8.8.8.8

# ── FreeRADIUS
RADIUS_HOST=freeradius
RADIUS_SECRET=CHANGE_ME_RADIUS_SECRET_STRONG
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813

# ── MikroTik (defaults, can be overridden per-router in DB)
MIKROTIK_DEFAULT_API_PORT=8729
MIKROTIK_API_TIMEOUT_MS=5000

# ── Starlink
STARLINK_IP=192.168.100.1

# ── Payment
BKASH_NUMBER=01XXXXXXXXX
NAGAD_NUMBER=01XXXXXXXXX
ROCKET_NUMBER=01XXXXXXXXX

# ── Domain
DOMAIN=skynity.net
ADMIN_SUBDOMAIN=dashboard
HOTSPOT_PORTAL_URL=https://hotspot.skynity.net

# ── Bootstrap (used only on first run)
BOOTSTRAP_ADMIN_EMAIL=admin@skynity.net
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_IMMEDIATELY
BOOTSTRAP_ORG_NAME=SKYNITY ISP

# ── Optional: SMS Gateway (SSL Wireless / Muthofun)
SMS_API_URL=
SMS_API_KEY=
SMS_SENDER_ID=SKYNITY

# ── Optional: bKash Payment Gateway
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
