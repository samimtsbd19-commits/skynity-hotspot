# ── App
NODE_ENV=production
PORT_API=3001
PORT_WEB=3000
MIKROTIK_MOCK=false

# ── Domain (skynity.org দিলে বাকি সব subdomain স্বয়ংক্রিয়)
DOMAIN=skynity.org

# ── URLs
APP_URL=https://admin.skynity.org
USER_PORTAL_URL=https://user.skynity.org
HOTSPOT_PORTAL_URL=https://wifi.skynity.org

# ── Next.js Build-time URLs (docker-compose build args হিসেবেও ব্যবহার হয়)
NEXT_PUBLIC_API_URL=https://api.skynity.org
NEXT_PUBLIC_ADMIN_URL=https://admin.skynity.org
NEXT_PUBLIC_USER_PORTAL_URL=https://user.skynity.org/portal

# ── PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=skynity
POSTGRES_USER=skynity_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── Auth
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING_HERE_USE_OPENSSL
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX_FOR_AES256

# ── Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CUSTOMER_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=

# ── WireGuard (setup.sh স্বয়ংক্রিয় generate করবে)
WG_SERVER_PRIVATE_KEY=GENERATED_ON_SETUP
WG_SERVER_PUBLIC_KEY=GENERATED_ON_SETUP
WG_SERVER_IP=10.100.0.1/24
WG_LISTEN_PORT=51820

# ── FreeRADIUS
RADIUS_HOST=freeradius
RADIUS_SECRET=CHANGE_ME_RADIUS_SECRET_STRONG
RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813

# ── MikroTik
MIKROTIK_HOST=10.100.0.2
MIKROTIK_USERNAME=skynity-api
MIKROTIK_PASSWORD=CHANGE_ME_MIKROTIK_PASSWORD
MIKROTIK_DEFAULT_API_PORT=8729
MIKROTIK_USE_SSL=true
MIKROTIK_API_TIMEOUT_MS=5000

# ── Payment
BKASH_NUMBER=01XXXXXXXXX
NAGAD_NUMBER=01XXXXXXXXX
ROCKET_NUMBER=01XXXXXXXXX

# ── Bootstrap (প্রথম run-এ admin user তৈরি করে)
BOOTSTRAP_ADMIN_EMAIL=admin@skynity.org
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_IMMEDIATELY
BOOTSTRAP_ORG_NAME=SKYNITY ISP

# ── Optional: SMS Gateway
SMS_API_URL=
SMS_API_KEY=
SMS_SENDER_ID=SKYNITY

# ── Optional: bKash Payment Gateway
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
